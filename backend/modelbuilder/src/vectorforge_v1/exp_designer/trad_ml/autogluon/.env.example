AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=anthropic/claude-sonnet-4.6
VECTORFORGE_PLANNER_PROVIDER=ai_gateway
VECTORFORGE_AUTOGLUON_AI_GATEWAY_MODEL=anthropic/claude-sonnet-4.6
VECTORFORGE_NARRATIVE_AI_GATEWAY_MODEL=anthropic/claude-sonnet-4.6
AUTORAG_AGENT_MODEL=anthropic/claude-sonnet-4.6
AUTORAG_AGENT_GEVAL_MODEL=anthropic/claude-sonnet-4.6
AUTORAG_AGENT_EMBEDDING_MODEL=openai/text-embedding-3-small

# S3 downloader / orchestrator
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-west-2
S3_DOWNLOAD_BUCKET_NAME=vector-forge-s3
S3_DOWNLOAD_OBJECT_KEY=datasets/enriched_telecom_churn-2.csv
S3_DOWNLOAD_OUTPUT_PATH=~/Downloads/enriched_telecom_churn-2.csv
S3_DOWNLOAD_EXPIRES_IN=3600

# Artifact forge / smoke
VECTORFORGE_SMOKE_BACKEND=local
# OPENSANDBOX_DOMAIN=localhost:8080
VECTORFORGE_SMOKE_DEPTH=contract
VECTORFORGE_ARTIFACT_SMOKE_TIMEOUT_SECONDS=120
