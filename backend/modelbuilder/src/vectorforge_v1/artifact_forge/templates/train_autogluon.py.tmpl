from __future__ import annotations

import argparse
import json
import shutil
from pathlib import Path


_HERE = Path(__file__).parent


def main() -> None:
    parser = argparse.ArgumentParser(description="Retrain the VectorForge AutoGluon artifact.")
    parser.add_argument("--dataset", required=True, help="Path to training CSV dataset.")
    parser.add_argument("--target", required=True, help="Target column name.")
    parser.add_argument("--time-limit", type=int, default=300, help="AutoGluon time limit in seconds.")
    parser.add_argument("--presets", default="medium_quality", help="AutoGluon presets.")
    parser.add_argument("--output-dir", default=None, help="Output model directory (default: overwrites model/).")
    args = parser.parse_args()

    from autogluon.tabular import TabularPredictor
    import pandas as pd

    manifest_path = _HERE / "manifest.json"
    with manifest_path.open(encoding="utf-8") as f:
        manifest = json.load(f)

    eval_metric = manifest.get("primary_metric", "auto")
    df = pd.read_csv(args.dataset)
    out_dir = Path(args.output_dir) if args.output_dir else _HERE / "model"

    predictor = TabularPredictor(
        label=args.target,
        eval_metric=eval_metric,
        path=str(out_dir),
    ).fit(df, time_limit=args.time_limit, presets=args.presets)

    print(f"Retrained model saved to: {out_dir}")
    print(f"Leaderboard:\n{predictor.leaderboard(silent=True).to_string()}")


if __name__ == "__main__":
    main()
