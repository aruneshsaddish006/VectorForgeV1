"""
infer.py — AutoGluon tabular inference script.
Generated by VectorForge artifact_forge. Do NOT edit manually.

Usage:
    python infer.py --input sample_input.json
    python infer.py --input my_data.csv
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


_HERE = Path(__file__).parent


def main() -> None:
    parser = argparse.ArgumentParser(description="Run inference with the VectorForge AutoGluon artifact.")
    parser.add_argument("--input", required=True, help="Path to input JSON (list of dicts) or CSV file.")
    parser.add_argument("--output", default=None, help="Path to write predictions JSON (default: stdout).")
    args = parser.parse_args()

    from autogluon.tabular import TabularPredictor
    import pandas as pd

    predictor = TabularPredictor.load(str(_HERE / "model"))

    input_path = Path(args.input)
    if not input_path.exists():
        print(f"ERROR: input file not found: {input_path}", file=sys.stderr)
        sys.exit(1)

    if input_path.suffix.lower() == ".json":
        with input_path.open(encoding="utf-8") as f:
            raw = json.load(f)
        df = pd.DataFrame(raw if isinstance(raw, list) else [raw])
    else:
        df = pd.read_csv(input_path)

    predictions = predictor.predict(df).tolist()
    result = {"predictions": predictions, "count": len(predictions)}

    output_str = json.dumps(result, indent=2)
    if args.output:
        Path(args.output).write_text(output_str, encoding="utf-8")
        print(f"Predictions written to {args.output}")
    else:
        print(output_str)


if __name__ == "__main__":
    main()
