from __future__ import annotations

import argparse
import json
import shutil
from pathlib import Path


_HERE = Path(__file__).parent


def main() -> None:
    parser = argparse.ArgumentParser(description="Rebuild the VectorForge AutoRAG artifact pipeline.")
    parser.add_argument("--corpus", required=True, help="Path to corpus parquet file.")
    parser.add_argument("--qa", required=True, help="Path to QA evaluation parquet file.")
    parser.add_argument("--output-dir", default=None, help="Output project directory.")
    args = parser.parse_args()

    rag_config_path = _HERE / "model" / "rag_config.yaml"
    manifest_path = _HERE / "manifest.json"

    with manifest_path.open(encoding="utf-8") as f:
        manifest = json.load(f)

    import yaml
    with rag_config_path.open(encoding="utf-8") as f:
        rag_config = yaml.safe_load(f)

    out_dir = Path(args.output_dir) if args.output_dir else _HERE / "_retrain_run"
    out_dir.mkdir(parents=True, exist_ok=True)

    corpus_dest = out_dir / "corpus.parquet"
    qa_dest = out_dir / "qa.parquet"
    shutil.copy2(args.corpus, corpus_dest)
    shutil.copy2(args.qa, qa_dest)

    config_dest = out_dir / "rag_config.yaml"
    with config_dest.open("w", encoding="utf-8") as f:
        yaml.dump(rag_config, f, sort_keys=False)

    try:
        from autorag.evaluator import Evaluator
        evaluator = Evaluator(qa_data_path=str(qa_dest), corpus_data_path=str(corpus_dest))
        evaluator.start_trial(str(config_dest))
        print(f"AutoRAG rebuild complete. Results in: {out_dir}")
    except Exception as exc:
        print(f"AutoRAG rebuild error: {exc}")
        print(f"Config and corpus staged in: {out_dir}")


if __name__ == "__main__":
    main()
