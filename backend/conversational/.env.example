# VectorForge Conversational API — environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# ── LLM (Vercel AI Gateway) ────────────────────────────────────────────────
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key-here
# Optional: override the default model
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-6

# ── AWS S3 (dataset storage) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<>
AWS_SECRET_ACCESS_KEY=<>
AWS_REGION=us-east-1
S3_BUCKET_NAME=vforge-datasets

# ── Exa (dataset discovery) ─────────────────────────────────────────────────
EXA_API_KEY=your-exa-api-key-here

# ── AWS RDS PostgreSQL (LangGraph checkpointing) ────────────────────────────
# session_id (UUID) → checkpoint rows, queryable by other agents
DB_HOST=your-rds-instance.xxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# ── LLM defaults (optional overrides) ───────────────────────────────────────
LLM_MODEL=anthropic/claude-sonnet-4-6
LLM_MAX_TOKENS=4096
# Set to false if behind a corporate TLS-inspection proxy (Zscaler, Netskope, etc.)
LLM_SSL_VERIFY=true
